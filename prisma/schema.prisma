generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrderState {
  PENDING
  PROCESSING
  SHIPPED
  FINISHED
  CANCELLED
  STUCK
  REFUNDED
}

enum Currency {
  USD
  VES
}

// Basic registration flow
/*
1. New client sign in by registering a new User 
2. Is redirected to a dashboard where them can create many companies and its correspondant company config
3. Then, user can create products and categories for the company
4. Finally, every time a sale is performed, it is registered as a order 
5. 
*/

model User {
  id      Int       @id @default(autoincrement())
  name    String
  auth    Auth      @relation(fields: [authId], references: [id])
  authId  Int       @unique
  company Company[]
}

model Auth {
  id           Int    @id @default(autoincrement())
  email        String @unique
  passwordHash String
  user         User?
}

model Company {
  id        Int        @id @default(autoincrement())
  admin     User       @relation(fields: [adminId], references: [id])
  adminId   Int        @unique
  name      String
  createdAt DateTime   @default(now())
  
  // Relations
  categories            Category[]
  products              Product[]
  orders                Order[]
  orderPaymentMethods   OrderPaymentMethod[]
  orderShippingMethods  OrderShippingMethod[]
  shipmentOrigins       ShipmentOrigin[]
  companyConfig         CompanyConfig?
}

model CompanyConfig {
  id        Int        @id @default(autoincrement())
  colors    String[] // 3 main colors to use on the store
  currency  Currency // The currency used and corresponding to the price INT your products have @todo Create a controller "switchCurrency" that receives params currA, currB, convertionFactor (1 currA is X currB) and update all the product's prices accordingly -> This is useful in many cases like switching currencies 
  showOutOfStockProducts Boolean // Still show a card but disable the buy button and renders "out of stock" feedback on UI
  
  companyId Int        @unique
  company   Company    @relation(fields: [companyId], references: [id])
}

// If a company has multiple houses from where the products are sended, they can register them here
// This is totally optional, but good for acounting
// On the order, a copy of this address will be written for history purposes 
model ShipmentOrigin {
  id        Int        @id @default(autoincrement())
  address   String

  // 1 Company has many orders
  company       Company      @relation(fields: [companyId], references: [id])
  companyId     Int
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  sku         String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stock       Int // If 0, means "out of stock"

  // 1 Company has many products
  company     Company  @relation(fields: [companyId], references: [id])
  companyId   Int

  // many-to-many with Categories
  categories  Category[]
  
  // 1 Product has many images
  images      ProductImage[]

  // Relation with orders that include this product
  orderItems OrderItem[]
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String
  description String?

  // 1 Company has many categories
  company     Company  @relation(fields: [companyId], references: [id])
  companyId   Int

  // many-to-many with Products
  products    Product[]
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  url       String  // Your "image-url" column
  altText   String?
  
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int
}


model Order {
  id            Int          @id @default(autoincrement())
  state         OrderState   @default(PENDING)
    
  totalAmount   Decimal      @db.Decimal(10, 2)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Customer Data
  customer_firstName              String
  customer_lastName               String
  customer_whatsapp_number        String
  customer_identification_number  String
  customer_email                  String?  
  customer_address                String?

  // Shipping data 
  originFields Json? // From where was sended the order -> useful for companies with multiple houses. This could be modified from the orders panel once marked as "shipped"
  shipping_country                String
  shipping_city                   String
  shipping_zipCode                String

  shipping_name_at_purchase          String        
  shipping_description_at_purchase   String?
  shipping_provider_at_purchase      String // Zoom, MRW, FeDex...        
  shipping_fields_at_purchase        Json // [{label: description}]
  shipping_fields_response           Json // [{label: value}]


  // Payment Data
  payment_name_at_purchase          String        
  payment_description_at_purchase   String?
  payment_provider_at_purchase      String        
  payment_fields_at_purchase        Json // [{label: description}]
  payment_fields_response           Json // [{label: value}]


  // relations
  company       Company      @relation(fields: [companyId], references: [id])
  companyId     Int
  items                           OrderItem[]
  orderEvents   OrderEvent[] // history traseability
}

model OrderEvent {
  id        Int      @id @default(autoincrement())
  state     OrderState
  notes     String[]  // Where "stuckReason" would live -> format: [ISODateUTC]"reason" -> i.e: [2026-04-01T02:33:34.423Z] MRW stop working till next week
  createdAt DateTime @default(now())

  orderId   Int
  order     Order    @relation(fields: [orderId], references: [id])
}



model OrderItem {
  id        Int     @id @default(autoincrement())
  quantity  Int
  
  // Snapshot of product at time of purchase
  priceAtPurchase Decimal @db.Decimal(10, 2)
  currencyAtPurchase    Currency
  nameAtPurchase        String
  descriptionAtPurchase String?
  skuAtPurchase         String? 

  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   Int

  // Keep the link to the live product, but set to null if deleted
  productId             Int?
  product               Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

// Payment and Order Methods
model OrderPaymentMethod {
  id            Int           @id @default(autoincrement())
  name          String        // "Visa **** 1234"
  description   String?
  provider      String        // "Stripe", "paypal", other
  receiverFields String // where to pay (bank account number to transfer, holder ID, etc)
  fields        Json // [{label: description}] -> fields to be provided by the buyer like screenshot of the transaction

  // 1 Company has many payment methods
  company       Company      @relation(fields: [companyId], references: [id])
  companyId     Int
}

model OrderShippingMethod {
  id          Int     @id @default(autoincrement())
  name        String
  description   String?
  provider      String        // Zoom, MRW, delivery
  fields      Json // [{label: description}] -> fields to be provided by the buyer like shipment address or receiving agency id

  // 1 Company has many shipping methods
  company       Company      @relation(fields: [companyId], references: [id])
  companyId     Int
}